# ElevenLabs TTS (optional). Without any key the app uses the browser's free
# system Chinese voice. With a key it uses ElevenLabs for more natural audio.

# Server-side key — set in the Vercel dashboard (Settings → Environment Variables)
# or in .env.local when running `vercel dev`. Read by api/tts.js. NEVER commit a real key.
ELEVENLABS_API_KEY=

# Public flag that turns the ElevenLabs proxy ON. Set this to 1 in Vercel ALONGSIDE
# ELEVENLABS_API_KEY. Without it the app never calls /api/tts and uses the device voice.
# VITE_ELEVENLABS_ENABLED=1

# Local dev WITHOUT `vercel dev`: plain `npm run dev` doesn't serve /api/*, so set
# this to call ElevenLabs directly from the browser (dev only — it is inlined into
# the JS bundle, so don't ship a build made with this set).
# VITE_ELEVENLABS_API_KEY=
# Optional: a specific ElevenLabs voice id (defaults to a multilingual voice).
# VITE_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
